{
	"name": "@thetaformat/protocol",
	"version": "1.0.32",
	"type": "module",
	"license": "Apache-2.0",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"require": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"files": [
		"dist",
		"src",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thetaformat/protocol.git"
	},
	"homepage": "https://github.com/thetaformat/protocol#readme",
	"bugs": {
		"url": "https://github.com/thetaformat/protocol/issues"
	},
	"keywords": [
		"protocol",
		"digital-exam-paper",
		"ai-native"
	],
	"publishConfig": {
		"access": "public",
		"main": "./dist/index.js",
		"module": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js",
				"require": "./dist/index.js",
				"default": "./dist/index.js"
			}
		}
	},
	"scripts": {
		"build": "rm -rf dist && tsup && tsc --emitDeclarationOnly --declaration --declarationMap --outDir dist",
		"typecheck": "tsc --noEmit",
		"push": "git add . && git commit -m \"WIP\" && git push",
		"release": "pnpm run typecheck && pnpm run build && pnpm version patch --no-git-tag-version && git add . && git commit -m \"chore: bump version & release\" && git push && pnpm publish"
	},
	"dependencies": {
		"semver": "^7.8.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/semver": "^7.7.1",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"@types/node": "^22.19.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=22.19.0",
			"onFail": "error"
		},
		"packageManager": {
			"name": "pnpm",
			"version": ">=10.22.0",
			"onFail": "warn"
		}
	}
}
