{
	"name": "@thetaformat/protocol",
	"version": "1.0.7",
	"type": "module",
	"license": "Apache-2.0",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thetaformat/protocol.git"
	},
	"homepage": "https://github.com/thetaformat/protocol#readme",
	"bugs": {
		"url": "https://github.com/thetaformat/protocol/issues"
	},
	"keywords": [
		"protocol",
		"digital-exam-paper",
		"ai-native"
	],
	"scripts": {
		"build": "rm -rf dist && tsup && tsc --emitDeclarationOnly --declaration --declarationMap --outDir dist",
		"typecheck": "tsc --noEmit",
		"push": "git add . && git commit -m \"WIP\" && git push",
		"release": "pnpm run typecheck && pnpm run build && pnpm version patch --no-git-tag-version && git add . && git commit -m \"chore: bump version & release\" && git push && pnpm publish --access public"
	},
	"dependencies": {
		"semver": "^7.8.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/semver": "^7.7.1",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	},
	"packageManager": "pnpm@10.22.0",
	"engines": {
		"node": "=25.7.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
